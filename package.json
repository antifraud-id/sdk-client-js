{
  "name": "@antifraud/sdk-client-js",
  "version": "1.0.0",
  "description": "Antifraud Web Browser SDK — device fingerprint collection and session management",
  "type": "module",
  "main": "./dist/antifraud.cjs.js",
  "module": "./dist/antifraud.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/antifraud.esm.js",
      "require": "./dist/antifraud.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "jsdom": "^25.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.1.0"
  }
}
